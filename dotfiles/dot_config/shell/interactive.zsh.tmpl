# Zsh-specific interactive setup.
# Shared commands load first so completions attach to the final aliases.

# Load shared aliases and functions.

if [[ -r "$HOME/.config/shell/interactive.common.sh" ]]; then
  source "$HOME/.config/shell/interactive.common.sh"
fi

# Add Zsh completions for Python and pip.

if (( $+functions[compdef] )); then
  compdef _python python python3
  compdef _pip pip pip3
fi
