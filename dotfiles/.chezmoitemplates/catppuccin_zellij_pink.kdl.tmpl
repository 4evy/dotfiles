      emphasis_1 "{{ index $p "sky" }}"
      emphasis_2 "{{ index $p "green" }}"
      emphasis_3 "{{ index $p "pink" }}"
    }
    frame_unselected {
      base "{{ index $p "surface0" }}"
      emphasis_0 "{{ index $p "overlay0" }}"
      emphasis_1 "{{ index $p "overlay1" }}"
      emphasis_2 "{{ index $p "overlay2" }}"
      emphasis_3 "{{ index $p "surface1" }}"
    }
    frame_selected {
      base "{{ index $p "pink" }}"
      emphasis_0 "{{ index $p "peach" }}"
      emphasis_1 "{{ index $p "sky" }}"
      emphasis_2 "{{ index $p "mauve" }}"
      emphasis_3 "{{ index $p "lavender" }}"
    }
    frame_highlight {
      base "{{ index $p "peach" }}"
      emphasis_0 "{{ index $p "mauve" }}"
      emphasis_1 "{{ index $p "pink" }}"
      emphasis_2 "{{ index $p "peach" }}"
      emphasis_3 "{{ index $p "peach" }}"
    }
    exit_code_success {
      base "{{ index $p "green" }}"
      emphasis_0 "{{ index $p "sky" }}"
      emphasis_1 "{{ $panel }}"
      emphasis_2 "{{ index $p "pink" }}"
      emphasis_3 "{{ index $p "blue" }}"
    }
    exit_code_error {
      base "{{ index $p "red" }}"
      emphasis_0 "{{ index $p "yellow" }}"
      emphasis_1 "{{ index $p "maroon" }}"
      emphasis_2 "{{ index $p "peach" }}"
      emphasis_3 "{{ index $p "mauve" }}"
    }
    multiplayer_user_colors {
      player_1 "{{ index $p "pink" }}"
      player_2 "{{ index $p "blue" }}"
      player_3 "{{ index $p "mauve" }}"
