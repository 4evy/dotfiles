{{- $flavor := . -}}
{{- $ctp := include ".chezmoitemplates/catppuccin_palette.json" | fromJson -}}
{{- $p := index $ctp $flavor -}}
{{- $panel := index $p "mantle" -}}
{{- $ribbon := index $p "text" -}}
{{- if eq $flavor "latte" -}}
  {{- $panel = index $p "crust" -}}
  {{- $ribbon = index $p "subtext1" -}}
{{- end }}
    text_unselected {
      base "{{ index $p "text" }}"
      background "{{ $panel }}"
      emphasis_0 "{{ index $p "peach" }}"
      emphasis_1 "{{ index $p "sky" }}"
      emphasis_2 "{{ index $p "green" }}"
      emphasis_3 "{{ index $p "pink" }}"
    }
    text_selected {
      base "{{ index $p "text" }}"
      background "{{ index $p "surface2" }}"
      emphasis_0 "{{ index $p "peach" }}"
      emphasis_1 "{{ index $p "sky" }}"
      emphasis_2 "{{ index $p "green" }}"
      emphasis_3 "{{ index $p "pink" }}"
    }
    ribbon_selected {
      base "{{ $panel }}"
      background "{{ index $p "pink" }}"
      emphasis_0 "{{ index $p "red" }}"
      emphasis_1 "{{ index $p "peach" }}"
      emphasis_2 "{{ index $p "pink" }}"
      emphasis_3 "{{ index $p "blue" }}"
    }
    ribbon_unselected {
      base "{{ $panel }}"
      background "{{ $ribbon }}"
