From 1123d2f04fa2132932ae87a49a1f8cc9eaee1730 Mon Sep 17 00:00:00 2001
From: 4evy <git@evy.pink>
Date: Sun, 12 Jul 2026 18:35:57 +0300
Subject: [PATCH 3/5] embedded: honor command wait-after-command setting

Propagate the surface option instead of forcing command surfaces to remain open. Temporary editor surfaces need to close as soon as their command exits.
---
 src/apprt/embedded.zig | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/apprt/embedded.zig b/src/apprt/embedded.zig
index 7310159cc..78482fc75 100644
--- a/src/apprt/embedded.zig
+++ b/src/apprt/embedded.zig
@@ -532,7 +532,7 @@ pub const Surface = struct {
             const cmd = std.mem.sliceTo(c_command, 0);
             if (cmd.len > 0) {
                 config.command = .{ .shell = cmd };
-                config.@"wait-after-command" = true;
+                config.@"wait-after-command" = opts.wait_after_command;
             }
         }
 
